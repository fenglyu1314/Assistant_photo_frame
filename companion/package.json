{
  "name": "assistant-photo-frame",
  "version": "0.1.0",
  "description": "Assistant Photo Frame - Electron Companion App",
  "main": "./out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:dist": "electron-vite build && electron-builder --win",
    "postinstall": "electron-rebuild",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.assistant-photo-frame.app",
    "productName": "Assistant Photo Frame",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.png",
      "uninstallerIcon": "resources/icon.png"
    },
    "extraResources": [
      {
        "from": "templates/",
        "to": "templates/",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "out/**/*",
      "!node_modules/**/*",
      "node_modules/serialport/**/*",
      "node_modules/@serialport/**/*",
      "node_modules/electron-store/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "npmRebuild": true
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^3.7.1",
    "@serialport/bindings-cpp": "^12.0.1",
    "@tailwindcss/vite": "^4.1.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "vue": "^3.5.13"
  }
}
